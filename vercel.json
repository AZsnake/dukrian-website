    { "source": "/durian-season", "destination": "/durian-season/", "permanent": true },
    { "source": "/big-durians", "destination": "/big-durians/", "permanent": true },
    { "source": "/how-to-find-ripe-good-durian", "destination": "/how-to-find-ripe-good-durian/", "permanent": true },
